# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic (AI agent)
ANTHROPIC_API_KEY=sk-ant-xxx

# Kakao OAuth
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# NTS (국세청 사업자등록번호 인증)
NTS_API_KEY=your-nts-api-key

# PortOne (결제 - 토스페이먼츠)
PORTONE_API_SECRET=your-portone-secret
PORTONE_STORE_ID=your-store-id
PORTONE_TEST_MODE=true

# SolAPI (SMS/카카오 알림톡)
SOLAPI_API_KEY=your-solapi-key
SOLAPI_API_SECRET=your-solapi-secret
SOLAPI_TEST_MODE=true

# Hyphen (배달앱/카드/홈택스 데이터 연동)
HYPHEN_API_KEY=your-hyphen-key
HYPHEN_API_SECRET=your-hyphen-secret
HYPHEN_TEST_MODE=true

# Cron authentication
CRON_SECRET=your-cron-secret

# App URL (for deep links and message buttons)
NEXT_PUBLIC_APP_URL=http://localhost:2000
