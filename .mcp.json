{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/.mcp.schema.json",
  "mcpServers": {
    "context7": {
      "$comment": "Up-to-date documentation and code examples via Context7",
      "command": "cmd.exe",
      "args": ["/c", "npx -y @upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "$comment": "Step-by-step reasoning for complex problems",
      "command": "cmd.exe",
      "args": ["/c", "npx -y @modelcontextprotocol/server-sequential-thinking"]
    },
    "supabase": {
      "$comment": "Supabase project management and SQL execution",
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=kdswausexsnqdeghdmas"
    }
  },
  "staggeredStartup": {
    "enabled": true,
    "delayMs": 500,
    "connectionTimeout": 15000
  }
}
